---
// OptiCV Features Grid Section

import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import { Icon } from 'astro-icon/components'

const features = [
	{
		icon: 'bug-ant',
		title: 'Resume Autopsy',
		description:
			'See exactly why an ATS might reject your CV — and how to fix every issue, ranked by severity.'
	},
	{
		icon: 'chart-pie',
		title: 'Keyword Gap Analysis',
		description:
			'Get a match score against the job description, with the missing keywords highlighted before you apply.'
	},
	{
		icon: 'document-text',
		title: 'Summary Rewrites',
		description:
			'Pick from three AI-generated professional summaries, each crafted around a different angle of your experience.'
	},
	{
		icon: 'bolt',
		title: 'Stronger Bullet Points',
		description:
			'Turn flat duty descriptions into achievement-led bullets using the STAR method, with metrics where they matter.'
	},
	{
		icon: 'cliboard-document-check',
		title: 'Tailored Cover Letters',
		description:
			'Generate cover letter drafts written for the exact role — multiple variants so you can pick the voice that fits.'
	},
	{
		icon: 'light-bulb',
		title: 'Interview Prep',
		description:
			'Walk in ready. Get 10+ likely interview questions for the role, plus pointers on how to answer each one.'
	},
	{
		icon: 'linkedin',
		title: 'LinkedIn Profile Boost',
		description:
			"Get AI-tailored headline variants, a rewritten About section, skills to add, and profile recommendations — all aligned to the job you're targeting."
	}
]
---

<Section id="features">
	<Row>
		<Col span="12" align="center" classes="mb-12 max-w-4xl mx-auto">
			<h2 class="text-pretty">
				Everything you need to <strong>apply with confidence.</strong>
			</h2>
			<p class="pb-0 text-lg text-neutral-600 dark:text-neutral-400">
				Built around how recruiters and ATS actually read CVs.
			</p>
		</Col>
	</Row>
	<Row>
		{
			features.map((feature) => (
				<Col span="4" classes="mb-6">
					<div class="flex h-full flex-col gap-3 rounded-2xl border border-neutral-200 bg-white p-6 dark:border-neutral-700 dark:bg-neutral-800">
						<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100 dark:bg-primary-900/40">
							<Icon name={feature.icon} class="h-5 w-5 text-primary-600 dark:text-primary-400" />
						</div>
						<h3 class="font-headings text-lg font-semibold text-primary-700 dark:text-primary-400">
							{feature.title}
						</h3>
						<p class="text-sm text-neutral-600 dark:text-neutral-400">{feature.description}</p>
					</div>
				</Col>
			))
		}
	</Row>
</Section>
