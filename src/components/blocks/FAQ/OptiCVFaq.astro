---
// OptiCV FAQ Section

import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
import Accordion from '../../ui/Accordion.astro'
import Card from '../../ui/cards/partials/Card.astro'

import faqData from '../../../data/json-files/faqData.json'
---

<Section id="FAQ">
	<Row>
		<Col span="12" align="center" classes="mb-12 max-w-4xl mx-auto">
			<h2 class="text-pretty">Questions, <strong>answered.</strong></h2>
		</Col>
		<Col span="2" />
		<Col span="8">
			<Card classes="divide-y divide-neutral-100 dark:divide-neutral-800">
				{
					faqData.map((item) => (
						<Accordion title={item.question} text={item.reply} open={item.open} />
					))
				}
			</Card>
		</Col>
		<Col span="2" />
	</Row>
</Section>
