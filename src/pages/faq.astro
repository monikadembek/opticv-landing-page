---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import Hero from '../components/blocks/hero/PageHeader.astro'
import FAQ from '../components/blocks/FAQ/FaqSticky.astro'
import TextImage from '../components/blocks/basic/TextImage.astro'
import CTA from '../components/blocks/CTA/OptiCVCTA.astro'

// Data
import faqData from '../data/json-files/faqData.json'
// - FAQ Categories
const faqFeatures = faqData.filter((faq) => faq.category === 'features')
const faqPricing = faqData.filter((faq) => faq.category === 'pricing')
const faqPrivacy = faqData.filter((faq) => faq.category === 'privacy')

// Content
import faqImage from '../assets/faq/opticv-faq.jpg'
// - SEO
const SEO = {
	title: 'OptiCV | Frequently Asked Questions',
	description:
		'Find answers to common questions about OptiCV — how it works, what file formats are supported, how your data is protected, and what each pricing plan includes.'
}
// - Page Header
const header = {
	title: 'Got Questions About <strong>OptiCV</strong>?',
	text: 'Everything you need to know about optimizing your CV, staying ATS-ready, and landing more interviews.'
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={header.title} text={header.text} />
	<FAQ
		title="How OptiCV Works"
		text="Learn how OptiCV analyzes your CV, scores it against real job descriptions, and gives you actionable feedback — no prompt engineering required."
		data={faqFeatures}
	/>
	<TextImage
		title="Your CV, Optimized for the Jobs You Actually Want"
		text="OptiCV reads your CV and the job description together, then tells you exactly what to change. You get an ATS compatibility score, keyword gap analysis, and a tailored cover letter — all ready to export. No generic advice, no guesswork."
		image={faqImage}
		mobileImage={faqImage}
		imagePosition="left"
		offsetImage
		classes="bg-neutral-50 dark:bg-neutral-900 lg:!py-64"
	/>
	<FAQ
		title="Pricing & Privacy"
		text="Understand what's included in each plan, how cancellations work, and how OptiCV keeps your personal data safe."
		data={[...faqPricing, ...faqPrivacy]}
	/>
	<CTA />
</Layout>
