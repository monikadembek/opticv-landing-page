---
// Components
// - Layout
import Layout from '../layouts/Layout.astro'
// - UI
import Hero from '../components/blocks/hero/PageHeader.astro'
import Price from '../components/blocks/pricing/PricingColumns.astro'
import ATSCTA from '../components/blocks/CTA/ATSCTA.astro'
import OptiCVFeaturesListOnPricing from '../components/blocks/features/OptiCVFeaturesListOnPricing.astro'
import OptiCVFaqPricing from '../components/blocks/FAQ/OptiCVFaqPricing.astro'

// Content
// - SEO
const SEO = {
	title: 'OptiCV - pricing plans',
	description:
		'Discover the pricing plans for OptiCV. Check OptiCV for free and then upgrade to pro when you start job hunting'
}
// - Page Header
const header = {
	title: 'Choose the plan that works for <strong>your</strong> needs',
	text: 'Check the app for free and then when you start applying for jobs upgrade to pro plan '
}
---

<Layout title={SEO.title} description={SEO.description}>
	<Hero title={header.title} text={header.text} />
	<Price />
	<OptiCVFeaturesListOnPricing classes="bg-slate-50 dark:bg-neutral-900/40" />
	<OptiCVFaqPricing classes="" />
	<ATSCTA />
</Layout>
